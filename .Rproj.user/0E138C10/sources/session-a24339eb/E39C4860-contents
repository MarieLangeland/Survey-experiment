  scale_x_discrete(labels = c("Ap" = "Labour Party (Ap)\nTreatment", 
                              "Frp" = "Progress Party (Frp)\nTreatment")) +
  labs(x = "", y = "") +
  theme_classic() +
  theme(text = element_text(family = "serif", size = 14),
        legend.position = "none")


ggplot(modell_data, aes(x = term, y = estimate)) +
  geom_hline(yintercept = 0, linetype = "dashed", color = "gray50", linewidth = 0.8) +
  geom_linerange(aes(ymin = conf.low, ymax = conf.high), color = "#4B2C3E", size = 1)+
  geom_point(color = "#4B2C3E", size = 5) +
